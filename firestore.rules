rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && 
             request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'username']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             (!data.keys().contains('gymPlan') || data.gymPlan != null);
    }

    function isValidReading(data) {
      return data.keys().hasAll(['userId', 'value', 'type', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.value is number && data.value > 0 && data.value < 1000 &&
             data.type in ['fasting', 'post-meal', 'random'] &&
             data.timestamp == request.time;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['uid', 'name', 'username', 'weight', 'height', 'age', 'diet', 'updatedAt', 'gymPlan', 'gymFormData', 'glucose']);
      
      // Readings subcollection
      match /readings/{readingId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReading(request.resource.data);
        allow delete: if isOwner(userId);
      }
      
      // Plans subcollection
      match /plans/{planId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }
  }
}
